<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface"
    android:orientation="vertical">

    <!-- ================================= -->
    <!-- Top Navigation Bar                -->
    <!-- ================================= -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:background="@color/surface"
        android:elevation="2dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp">

        <!-- CampusGear text logo -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:text="Campus"
                android:textColor="@color/primary"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:text="Gear"
                android:textColor="@color/accent"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Spacer -->
        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- Hamburger menu icon -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="16dp"
            android:text="☰"
            android:textColor="@color/text_primary"
            android:textSize="20sp" />

        <!-- User avatar circle with initials -->
        <TextView
            android:id="@+id/tvUserInitials"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_marginEnd="10dp"
            android:background="@drawable/bg_avatar"
            android:fontFamily="sans-serif-medium"
            android:gravity="center"
            android:textColor="@color/text_on_primary"
            android:textSize="11sp"
            android:textStyle="bold" />

        <!-- Sign Out -->
        <TextView
            android:id="@+id/btnLogout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-medium"
            android:padding="4dp"
            android:text="Sign Out"
            android:textColor="@color/text_secondary"
            android:textSize="13sp" />

    </LinearLayout>

    <!-- Thin separator line -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider" />

    <!-- ================================= -->
    <!-- Scrollable Content                -->
    <!-- ================================= -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="20dp"
            android:paddingBottom="24dp">

            <!-- Marketplace heading -->
            <TextView
                android:id="@+id/tvWelcome"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Marketplace"
                android:textColor="@color/text_primary"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="16dp"
                android:text="Browse available equipment from students on your\ncampus."
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:lineSpacingExtra="2dp" />

            <!-- Search input -->
            <com.google.android.material.textfield.TextInputLayout
                style="@style/CampusGear.TextInputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:hintEnabled="false">

                <com.google.android.material.textfield.TextInputEditText
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Search equipment (e.g. Scientific Calculator, DSLR Came..."
                    android:inputType="text"
                    android:paddingVertical="12dp"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_hint"
                    android:textSize="13sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- All Categories dropdown -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_button_outline">

                <Spinner
                    android:id="@+id/spinnerCategory"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:paddingHorizontal="12dp" />
            </FrameLayout>

            <!-- Search button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSearch"
                style="@style/CampusGear.Button.Primary"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="10dp"
                android:text="Search" />

            <!-- Category chips (horizontal scroll) -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="16dp"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/bg_chip_selected"
                        android:fontFamily="sans-serif-medium"
                        android:paddingHorizontal="14dp"
                        android:paddingVertical="6dp"
                        android:text="All"
                        android:textColor="@color/text_on_primary"
                        android:textSize="12sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/bg_chip_unselected"
                        android:fontFamily="sans-serif-medium"
                        android:paddingHorizontal="14dp"
                        android:paddingVertical="6dp"
                        android:text="Electronics"
                        android:textColor="@color/text_label"
                        android:textSize="12sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/bg_chip_unselected"
                        android:fontFamily="sans-serif-medium"
                        android:paddingHorizontal="14dp"
                        android:paddingVertical="6dp"
                        android:text="Lab Equipment"
                        android:textColor="@color/text_label"
                        android:textSize="12sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/bg_chip_unselected"
                        android:fontFamily="sans-serif-medium"
                        android:paddingHorizontal="14dp"
                        android:paddingVertical="6dp"
                        android:text="Photography"
                        android:textColor="@color/text_label"
                        android:textSize="12sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/bg_chip_unselected"
                        android:fontFamily="sans-serif-medium"
                        android:paddingHorizontal="14dp"
                        android:paddingVertical="6dp"
                        android:text="Sports"
                        android:textColor="@color/text_label"
                        android:textSize="12sp" />
                </LinearLayout>
            </HorizontalScrollView>

            <!-- Second row of chips -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_chip_unselected"
                    android:fontFamily="sans-serif-medium"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="6dp"
                    android:text="Musical"
                    android:textColor="@color/text_label"
                    android:textSize="12sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_chip_unselected"
                    android:fontFamily="sans-serif-medium"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="6dp"
                    android:text="Books"
                    android:textColor="@color/text_label"
                    android:textSize="12sp" />
            </LinearLayout>

            <!-- Equipment Card 1: Scientific Calculator -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:background="@drawable/bg_card"
                android:orientation="vertical">

                <!-- Image placeholder -->
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="160dp"
                    android:background="@color/placeholder_bg">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="[Equipment Image Placeholder]"
                        android:textColor="@color/text_hint"
                        android:textSize="12sp" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Scientific Calculator"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="$5.00 / day"
                        android:textColor="@color/text_primary"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="Listed by Sarah M. — Electronics"
                        android:textColor="@color/text_hint"
                        android:textSize="11sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Equipment Card 2: DSLR Camera Kit -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:background="@drawable/bg_card"
                android:orientation="vertical">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="160dp"
                    android:background="@color/placeholder_bg">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="[Equipment Image Placeholder]"
                        android:textColor="@color/text_hint"
                        android:textSize="12sp" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="DSLR Camera Kit"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="$25.00 / day"
                        android:textColor="@color/text_primary"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="Listed by James R. — Photography"
                        android:textColor="@color/text_hint"
                        android:textSize="11sp" />
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
